# HnH LLM CTF - Environment Variables Configuration
# Copy this file to .env and modify as needed

# Ollama Configuration
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT=30

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=0

# Model Options (change OLLAMA_MODEL to one of these):
# - mistral (7B) - Recommended for VPS, fastest quality model
# - llama2 (7B) - Default, good all-around
# - neural-chat (7B) - Optimized for chat
# - phi (3.8B) - Very fast, smaller model
# - tinyllama (1.1B) - Fastest, good for low-resource systems
# - openchat (7B) - Fast and capable
